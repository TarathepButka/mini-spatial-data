{
  "info": {
    "name": "Mini Spatial Data Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1"
    },
    {
      "key": "featureId",
      "value": "replace-with-created-feature-id"
    },
    {
      "key": "googleCredential",
      "value": "paste-google-id-token-here"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "invalidToken",
      "value": "this-is-not-a-valid-token"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "List Collections",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/collections"
          }
        }
      ]
    },
    {
      "name": "2. Authentication (Require AUTH_REQUIRED=true)",
      "item": [
        {
          "name": "Google Login (Success) - Sets HttpOnly Cookie",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "var cookie = pm.cookies.get(\"mini_spatial_auth\");",
                  "if (cookie) {",
                  "    pm.collectionVariables.set(\"token\", cookie);",
                  "}",
                  "if (json.user && json.user.id) {",
                  "    pm.collectionVariables.set(\"userId\", json.user.id);",
                  "}",
                  "pm.test('token saved', function () { pm.expect(cookie).to.be.a('string'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/google",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credential\": \"{{googleCredential}}\"\n}"
            }
          }
        },
        {
          "name": "Google Login (Error - 401 Invalid Credential)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 401', function () { pm.response.to.have.status(401); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/google",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credential\": \"invalid-token-example\"\n}"
            }
          }
        },
        {
          "name": "Google Login (Error - 401 Empty Credential)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 401', function () { pm.response.to.have.status(401); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/google",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credential\": \"\"\n}"
            }
          }
        },
        {
          "name": "Current User (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Switch Active Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/role",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Switch Active Role (Error - 403 Forbidden Role)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 403', function () { pm.response.to.have.status(403); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/role",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"invalid-role\"\n}"
            }
          }
        },
        {
          "name": "Logout - Clears Cookie",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "3. Spatial Features",
      "item": [
        {
          "name": "Read",
          "item": [
            {
              "name": "List Features (Pagination)",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/features?page=1&limit=20"
              }
            },
            {
              "name": "List Features (Search & Filters)",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/features?page=1&limit=20&search=hotspot&collection=hotspots&category=nominal&province=Suphan%20Buri"
              }
            },
            {
              "name": "List Features (BBox)",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/features?page=1&limit=20&bbox=99.5,13.0,101.5,16.0"
              }
            },
            {
              "name": "Get Feature by ID",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/features/{{featureId}}"
              }
            },
            {
              "name": "Nearby Features (Radius Query)",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/features/nearby?lng=100.5018&lat=13.7563&radius=5000"
              }
            },
            {
              "name": "Get Feature (Error - 404 Not Found)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('status is 404', function () { pm.response.to.have.status(404); });"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/features/60a0a0a0a0a0a0a0a0a0a0a0"
              }
            },
            {

                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
                      "var jsonData = pm.response.json();",
                      "if (jsonData && jsonData.id) {",
                      "    pm.collectionVariables.set(\"featureId\", jsonData.id);",
                      "}"
                    ],
                    "type": "text/javascript"
